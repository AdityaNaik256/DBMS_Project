# Copy this file to backend/.env and fill in your MySQL credentials
#
# Local development — set these manually:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=tournament_db
PORT=3000

# Railway deployment — Railway automatically injects these when you add a
# MySQL plugin to your project (no manual action needed):
# MYSQLHOST=...
# MYSQLPORT=...
# MYSQLUSER=...
# MYSQLPASSWORD=...
# MYSQLDATABASE=...
